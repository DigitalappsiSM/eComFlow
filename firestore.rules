rules_version = '2';

// ==========================================================================
// eComFlow Next — Firestore Security Rules (§27, §30)
//
// Principios:
//   - Requiere autenticación en todo acceso.
//   - Requiere que exista users/{uid} y que el usuario esté activo.
//   - Autoriza lectura/escritura según rol.
//   - Prohíbe eliminaciones físicas (toda baja es lógica: active=false).
//   - Protege identificadores internos, created_at y created_by.
//   - Exige que created_by / updated_by coincidan con request.auth.uid.
//   - Impide que un usuario cambie su propio rol.
//   - Rechaza colecciones no declaradas (default deny al final).
//
// NOTA: estas reglas son la base de la primera entrega. Las validaciones de
// contenido por colección se irán endureciendo en fases posteriores.
// ==========================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------- helpers ------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return userExists() && userDoc().active == true;
    }

    function role() {
      return isActiveUser() ? userDoc().role : 'none';
    }

    function hasRole(roles) {
      return role() in roles;
    }

    function canRead() {
      // Cualquier usuario activo puede leer los datos operativos.
      return isActiveUser();
    }

    function canWriteOperational() {
      return hasRole(['admin', 'manager', 'operator']);
    }

    function canManageCatalog() {
      return hasRole(['admin', 'manager']);
    }

    // Crear/confirmar importaciones: SOLO admin/manager. El operator (KAM)
    // trabaja checks operativos, responsables y comentarios, pero no importa.
    function canWriteImports() {
      return hasRole(['admin', 'manager']);
    }

    function isAdmin() {
      return hasRole(['admin']);
    }

    // Interruptor de reinicio SOLO para pruebas: permite borrado físico
    // (truncate) únicamente cuando app_settings.dev_reset_enabled == true.
    // Por defecto es false → los `delete` quedan bloqueados (producción segura).
    function devResetEnabled() {
      return exists(/databases/$(database)/documents/app_settings/global)
        && get(/databases/$(database)/documents/app_settings/global)
             .data.get('dev_reset_enabled', false) == true;
    }

    function canResetData() {
      return isAdmin() && devResetEnabled();
    }

    // No se puede tocar created_at / created_by en una actualización.
    function immutableCreation() {
      return request.resource.data.created_at == resource.data.created_at
        && request.resource.data.created_by == resource.data.created_by;
    }

    // updated_by debe ser el usuario autenticado.
    function updatedByIsCaller() {
      return request.resource.data.updated_by == request.auth.uid;
    }

    // created_by debe ser el usuario autenticado en una creación.
    function createdByIsCaller() {
      return request.resource.data.created_by == request.auth.uid;
    }

    // ---- Validaciones de importaciones (endurecimiento §22, §25) ----
    // Campos de identidad/procedencia inmutables tras crear el registro.
    function importFieldsImmutable() {
      return request.resource.data.import_id == resource.data.import_id
        && request.resource.data.file_hash == resource.data.file_hash
        && request.resource.data.file_name == resource.data.file_name
        && request.resource.data.file_size == resource.data.file_size
        && request.resource.data.uploaded_at == resource.data.uploaded_at
        && request.resource.data.uploaded_by == resource.data.uploaded_by;
    }

    // Transiciones válidas: solo desde 'processing' a un estado terminal, o
    // dejar el estado igual (actualizaciones de progreso/cierre parcial).
    function importStatusTransitionOk() {
      return request.resource.data.status == resource.data.status
        || (resource.data.status == 'processing'
            && request.resource.data.status in
               ['processed', 'partially_processed', 'failed', 'cancelled']);
    }

    // finished_at solo puede quedar establecido en un estado terminal.
    function importFinishedOnlyTerminal() {
      return request.resource.data.finished_at == null
        || request.resource.data.status in
           ['processed', 'partially_processed', 'failed', 'cancelled'];
    }

    // last_confirmed_batch nunca disminuye.
    function importBatchNotDecreasing() {
      return request.resource.data.get('last_confirmed_batch', 0)
        >= resource.data.get('last_confirmed_batch', 0);
    }

    // ---- Validaciones de cambios detectados (endurecimiento §43) ----
    // La relación con campaña/línea/importación y la procedencia son inmutables.
    function detectedChangeImmutable() {
      return request.resource.data.detected_change_id == resource.data.detected_change_id
        && request.resource.data.campaign_group_id == resource.data.campaign_group_id
        && request.resource.data.campaign_space_id == resource.data.campaign_space_id
        && request.resource.data.campaign_line_id == resource.data.campaign_line_id
        && request.resource.data.import_id == resource.data.import_id
        && request.resource.data.created_at == resource.data.created_at
        && request.resource.data.created_by == resource.data.created_by;
    }

    // Baja lógica únicamente: nunca se permite `delete`.
    // (No se define ninguna regla `allow delete`, por lo que queda prohibido.)

    // ---------------------- users --------------------------------------
    match /users/{uid} {
      // Un usuario puede leer su propio doc; admin puede leer todos.
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());

      // La creación de usuarios y asignación de roles se hace desde la
      // consola de Firebase / Admin, no desde el navegador.
      allow create: if false;

      // Solo admin puede modificar usuarios, y nadie puede cambiar su
      // propio rol.
      allow update: if isAdmin()
        && !(request.auth.uid == uid
             && request.resource.data.role != resource.data.role);

      allow delete: if false;
    }

    // ---------------------- catálogo -----------------------------------
    match /placements/{id} {
      allow read: if canRead();
      allow create: if canManageCatalog() && createdByIsCaller();
      allow update: if canManageCatalog() && immutableCreation() && updatedByIsCaller();
      allow delete: if false;
    }

    match /placement_requirements/{id} {
      allow read: if canRead();
      allow create: if canManageCatalog() && createdByIsCaller();
      allow update: if canManageCatalog() && immutableCreation() && updatedByIsCaller();
      allow delete: if false;
    }

    // ---------------------- campañas / jerarquía -----------------------
    // NOTA: `allow delete` en las colecciones OPERATIVAS está permitido SOLO
    // para admin y SOLO con el interruptor de pruebas encendido (canResetData).
    // Con el interruptor apagado (por defecto), el borrado queda bloqueado.
    match /campaign_groups/{id} {
      allow read: if canRead();
      allow create: if canWriteOperational() && createdByIsCaller();
      allow update: if canWriteOperational() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    match /campaign_spaces/{id} {
      allow read: if canRead();
      allow create: if canWriteOperational() && createdByIsCaller();
      allow update: if canWriteOperational() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    match /campaign_lines/{id} {
      allow read: if canRead();
      allow create: if canWriteOperational() && createdByIsCaller();
      allow update: if canWriteOperational() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    match /campaign_line_requirements/{id} {
      allow read: if canRead();
      // Snapshot escrito por el importador; created_by debe ser el llamador.
      allow create: if canWriteOperational() && createdByIsCaller();
      // Snapshot inmutable: no se permite actualizar (histórico fiel).
      allow update: if false;
      allow delete: if canResetData();
    }

    // ---------------------- operación ----------------------------------
    match /campaign_operations/{id} {
      allow read: if canRead();
      allow create: if canWriteOperational() && createdByIsCaller();
      allow update: if canWriteOperational() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    match /campaign_comments/{id} {
      allow read: if canRead();
      allow create: if canWriteOperational() && createdByIsCaller();
      // Un comentario sólo se archiva (active=false) o edita por su autor
      // o por un admin.
      allow update: if canWriteOperational()
        && immutableCreation()
        && (resource.data.created_by == request.auth.uid || isAdmin());
      allow delete: if canResetData();
    }

    match /detected_changes/{id} {
      allow read: if canRead();
      // Crea el importador (rol operativo); id del doc == detected_change_id.
      allow create: if canWriteOperational()
        && createdByIsCaller()
        && request.resource.data.detected_change_id == id;
      // Solo revisión/estado; la relación con campaña/línea/importación y la
      // procedencia quedan inmutables.
      allow update: if canWriteOperational()
        && updatedByIsCaller()
        && detectedChangeImmutable();
      allow delete: if canResetData();
    }

    // ---------------------- importaciones ------------------------------
    match /imports/{id} {
      allow read: if canRead();
      // Solo admin/manager crean; el id del doc == import_id; arranca 'processing'.
      allow create: if canWriteImports()
        && createdByIsCaller()
        && request.resource.data.import_id == id
        && request.resource.data.status == 'processing';
      // Solo admin/manager actualizan; identidad/creación inmutables; solo
      // transiciones válidas de estado; finished_at solo en terminales;
      // last_confirmed_batch no disminuye.
      allow update: if canWriteImports()
        && updatedByIsCaller()
        && immutableCreation()
        && importFieldsImmutable()
        && importStatusTransitionOk()
        && importFinishedOnlyTerminal()
        && importBatchNotDecreasing();
      allow delete: if canResetData();
    }

    match /import_rows/{id} {
      allow read: if canRead();
      // Solo admin/manager crean; si trae created_by debe ser el llamador.
      allow create: if canWriteImports()
        && (!('created_by' in request.resource.data)
            || createdByIsCaller());
      // Las filas de importación son inmutables (histórico fiel).
      allow update: if false;
      allow delete: if canResetData();
    }

    // ---------------------- auditoría ----------------------------------
    match /change_history/{id} {
      allow read: if canRead();
      // La auditoría es append-only: se crea, nunca se modifica.
      allow create: if canWriteOperational() && createdByIsCaller();
      allow update: if false;
      allow delete: if canResetData();
    }

    // ---------------------- configuración ------------------------------
    match /app_settings/{id} {
      allow read: if canRead();
      allow write: if isAdmin();
    }

    // ====================================================================
    // MÓDULO RESULTADOS ECOMMERCE (Kevel) — dominio independiente (§3, §27).
    // Los permisos de Resultados NO otorgan acceso a Operación ni viceversa.
    // Ninguna colección results_* acepta escrituras desde flujos operativos
    // (los repos operativos no las referencian) y aquí se separan los roles.
    // ====================================================================

    // Importa resultados: admin/manager/operator (operator actúa como KAM).
    function canWriteResults() {
      return hasRole(['admin', 'manager', 'operator']);
    }

    // Mapeos/vínculos y catálogo de periodos: solo admin/manager.
    function canManageResultsMappings() {
      return hasRole(['admin', 'manager']);
    }

    // Aprobación de ajustes comerciales: solo admin/manager.
    function canApproveAdjustments() {
      return hasRole(['admin', 'manager']);
    }

    // Catálogo COMPARTIDO de periodos ecommerce (viernes→jueves). Resultados
    // lo lee; solo admin/manager lo siembran. Nunca se borra.
    match /ecommerce_periods/{id} {
      allow read: if canRead();
      allow create: if canManageResultsMappings() && createdByIsCaller();
      allow update: if canManageResultsMappings() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    match /results_imports/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller();
      // Solo transiciones de estado de la propia importación (reanudar/cerrar).
      allow update: if canWriteResults() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    // Resultados diarios REALES: inmutables tras crearse (§9). Nunca update.
    match /results_daily/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller();
      allow update: if false;
      allow delete: if canResetData();
    }

    // Consolidado semanal: lo reconstruye el importador (mismos IDs
    // deterministas). No admite valores ajustados (viven en allocations).
    match /results_weekly/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller();
      allow update: if canWriteResults() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    match /results_validation_issues/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller();
      allow update: if false;
      allow delete: if canResetData();
    }

    // Colecciones puente (vínculos opcionales y reversibles, §13).
    match /results_campaign_links/{id} {
      allow read: if canRead();
      allow create: if canManageResultsMappings() && createdByIsCaller();
      allow update: if canManageResultsMappings() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }
    match /results_advertiser_mappings/{id} {
      allow read: if canRead();
      allow create: if canManageResultsMappings() && createdByIsCaller();
      allow update: if canManageResultsMappings() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }
    match /results_placement_mappings/{id} {
      allow read: if canRead();
      allow create: if canManageResultsMappings() && createdByIsCaller();
      allow update: if canManageResultsMappings() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }
    match /results_device_mappings/{id} {
      allow read: if canRead();
      allow create: if canManageResultsMappings() && createdByIsCaller();
      allow update: if canManageResultsMappings() && immutableCreation() && updatedByIsCaller();
      allow delete: if canResetData();
    }

    // Ajustes comerciales (§16–§22). Solo borradores editables; lo aprobado es
    // inmutable; las métricas ajustables nunca son ratios (se valida en app y
    // se endurecerá aquí en la fase de ajustes).
    match /results_adjustment_sets/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller()
        && request.resource.data.status == 'draft';
      // Editar solo si sigue en borrador, o transición de estado por aprobador.
      allow update: if immutableCreation() && updatedByIsCaller()
        && (
          (canWriteResults() && resource.data.status == 'draft')
          || (canApproveAdjustments()
              && resource.data.status in ['draft', 'pending_approval', 'approved'])
        );
      allow delete: if canResetData();
    }

    match /results_weekly_adjustments/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller()
        && request.resource.data.status == 'draft'
        && request.resource.data.metric in ['impressions', 'clicks', 'unique_clicks'];
      allow update: if immutableCreation() && updatedByIsCaller()
        && (
          (canWriteResults() && resource.data.status == 'draft')
          || (canApproveAdjustments()
              && resource.data.status in ['draft', 'pending_approval'])
        );
      allow delete: if canResetData();
    }

    // Allocations: SOLO las materializa la aprobación (admin/manager). Nunca
    // se editan a mano.
    match /results_weekly_adjustment_allocations/{id} {
      allow read: if canRead();
      allow create: if canApproveAdjustments() && createdByIsCaller();
      allow update: if false;
      allow delete: if canResetData();
    }

    // Auditoría de Resultados: append-only, separada de change_history.
    match /results_adjustment_history/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller();
      allow update: if false;
      allow delete: if canResetData();
    }
    match /results_change_history/{id} {
      allow read: if canRead();
      allow create: if canWriteResults() && createdByIsCaller();
      allow update: if false;
      allow delete: if canResetData();
    }

    // ---------------------- default deny -------------------------------
    // Rechaza cualquier colección no declarada arriba.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
