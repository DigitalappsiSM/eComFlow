# eComFlow Next — configuración de Firebase (cliente Web SDK)
# Copia este archivo como `.env` y rellena con los valores de tu proyecto
# de Firebase (Consola de Firebase → Configuración del proyecto → Tus apps → Web).
#
# NUNCA incluyas aquí credenciales administrativas, Service Accounts ni
# archivos JSON secretos. Estas variables son claves públicas de cliente.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Emulator Suite (opcional). Ponlo en "true" para conectar la app a los
# emuladores locales de Auth y Firestore en lugar del proyecto real.
VITE_USE_FIREBASE_EMULATORS=false
